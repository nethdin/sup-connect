      "name": "Authentication",
      "item": [
        {
          "name": "Register Student",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('TOKEN', jsonData.token);",
                  "    pm.environment.set('STUDENT_TOKEN', jsonData.token);",
                  "    pm.environment.set('CURRENT_USER_ID', jsonData.user.id);",
                  "    pm.environment.set('CURRENT_USER_ROLE', jsonData.user.role);",
                  "    console.log('STUDENT_TOKEN captured: ' + jsonData.token.substring(0, 20) + '...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@example.com\",\n  \"password\": \"SecurePass123\",\n  \"name\": \"John Student\",\n  \"role\": \"STUDENT\",\n  \"department\": \"Computer Science\",\n  \"registrationNo\": \"CS001\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/register",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
