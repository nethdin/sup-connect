            "body": {
              "mode": "raw",
              "raw": "{\n  \"supervisorId\": \"{{supervisorId}}\",\n  \"dateTime\": \"2024-12-20T10:00:00Z\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "NOTIFICATIONS",
      "item": [
        {
          "name": "Get Notifications",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/notifications?unread=false&limit=50",
              "query": [
                {
                  "key": "unread",
                  "value": "false"
                },
                {
                  "key": "limit",
                  "value": "50"
                }
              ]
            }
          }
        },
        {
          "name": "Mark Notification as Read",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/notifications",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notificationId\": \"{{notificationId}}\"\n}"
            }
          }
        },
        {
          "name": "Mark All Notifications as Read",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/notifications",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"markAllRead\": true\n}"
            }
          }
        },
        {
          "name": "Delete Notification",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/notifications?id={{notificationId}}",
              "query": [
                {
                  "key": "id",
                  "value": "{{notificationId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Delete All Notifications",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/notifications?all=true",
              "query": [
                {
                  "key": "all",
                  "value": "true"
                }
              ]
            }
          }
        }
      ]
