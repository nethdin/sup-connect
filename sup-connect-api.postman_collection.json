        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('TOKEN', jsonData.token);",
                  "    var role = jsonData.user.role;",
                  "    if (role === 'STUDENT') {",
                  "        pm.environment.set('STUDENT_TOKEN', jsonData.token);",
                  "    } else if (role === 'SUPERVISOR') {",
                  "        pm.environment.set('SUPERVISOR_TOKEN', jsonData.token);",
                  "    } else if (role === 'ADMIN' || role === 'SUPER_ADMIN') {",
                  "        pm.environment.set('ADMIN_TOKEN', jsonData.token);",
                  "    }",
                  "    pm.environment.set('CURRENT_USER_ID', jsonData.user.id);",
                  "    pm.environment.set('CURRENT_USER_ROLE', role);",
                  "    console.log('Login successful for ' + role + ' - Token captured');",
                  "}",
                  ""
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
