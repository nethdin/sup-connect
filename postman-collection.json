{
  "info": {
    "name": "sup-connect API",
    "description": "Complete API collection for sup-connect application",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api",
      "type": "string"
    },
    {
      "key": "studentToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "supervisorToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Student",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('studentToken', response.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@test.com\",\n  \"password\": \"student123\",\n  \"name\": \"John Student\",\n  \"role\": \"STUDENT\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Register Supervisor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('supervisorToken', response.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"supervisor@test.com\",\n  \"password\": \"supervisor123\",\n  \"name\": \"Dr. Smith\",\n  \"role\": \"SUPERVISOR\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@test.com\",\n  \"password\": \"student123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Supervisors",
      "item": [
        {
          "name": "Get All Supervisors",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/supervisors?available=true",
              "host": ["{{baseUrl}}"],
              "path": ["supervisors"],
              "query": [
                {
                  "key": "available",
                  "value": "true"
                },
                {
                  "key": "specialization",
                  "value": "Machine Learning",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "Get Supervisor by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/supervisors/:id",
              "host": ["{{baseUrl}}"],
              "path": ["supervisors", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "sup123"
                }
              ]
            }
          }
        },
        {
          "name": "Create Supervisor Profile",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{supervisorToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"specialization\": \"Machine Learning\",\n  \"tags\": [\"AI\", \"Deep Learning\", \"NLP\", \"Computer Vision\"],\n  \"bio\": \"Expert in Machine Learning with 10 years of experience in AI research and development.\",\n  \"maxSlots\": 5\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/supervisor/profile",
              "host": ["{{baseUrl}}"],
              "path": ["supervisor", "profile"]
            }
          }
        },
        {
          "name": "Get Supervisor Requests",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{supervisorToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/supervisor/requests?status=PENDING",
              "host": ["{{baseUrl}}"],
              "path": ["supervisor", "requests"],
              "query": [
                {
                  "key": "status",
                  "value": "PENDING"
                }
              ]
            }
          }
        },
        {
          "name": "Accept Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{supervisorToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/supervisor/requests/:id/accept",
              "host": ["{{baseUrl}}"],
              "path": ["supervisor", "requests", ":id", "accept"],
              "variable": [
                {
                  "key": "id",
                  "value": "req123"
                }
              ]
            }
          }
        },
        {
          "name": "Decline Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{supervisorToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/supervisor/requests/:id/decline",
              "host": ["{{baseUrl}}"],
              "path": ["supervisor", "requests", ":id", "decline"],
              "variable": [
                {
                  "key": "id",
                  "value": "req123"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Student",
      "item": [
        {
          "name": "Submit Project Idea",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"AI-Powered Chatbot for Customer Service\",\n  \"description\": \"Build an intelligent chatbot using natural language processing and machine learning to handle customer inquiries automatically.\",\n  \"category\": \"Artificial Intelligence\",\n  \"keywords\": [\"NLP\", \"chatbot\", \"machine learning\", \"AI\", \"customer service\"]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/student/idea",
              "host": ["{{baseUrl}}"],
              "path": ["student", "idea"]
            }
          }
        },
        {
          "name": "Get Recommendation Matches",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/student/matches",
              "host": ["{{baseUrl}}"],
              "path": ["student", "matches"]
            }
          }
        },
        {
          "name": "Send Booking Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"supervisorId\": \"sup123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/student/request",
              "host": ["{{baseUrl}}"],
              "path": ["student", "request"]
            }
          }
        }
      ]
    },
    {
      "name": "Meetings",
      "item": [
        {
          "name": "Get All Meetings",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/meetings?upcoming=true",
              "host": ["{{baseUrl}}"],
              "path": ["meetings"],
              "query": [
                {
                  "key": "upcoming",
                  "value": "true"
                }
              ]
            }
          }
        },
        {
          "name": "Book Meeting Slot",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"supervisorId\": \"sup123\",\n  \"dateTime\": \"2025-11-01T14:00:00.000Z\",\n  \"mode\": \"ONLINE\",\n  \"notes\": \"Discuss project proposal and timeline\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/availability/book",
              "host": ["{{baseUrl}}"],
              "path": ["availability", "book"]
            }
          }
        }
      ]
    }
  ]
}
